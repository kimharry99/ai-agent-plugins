{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=\"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}\"; [ -n \"$ROOT\" ] || exit 0; SCRIPT=\"$ROOT/hooks/rule-reminder.sh\"; [ -f \"$SCRIPT\" ] || exit 0; exec bash \"$SCRIPT\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'ROOT=\"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}\"; [ -n \"$ROOT\" ] || exit 0; SCRIPT=\"$ROOT/hooks/check-python-rules.sh\"; [ -f \"$SCRIPT\" ] || exit 0; exec bash \"$SCRIPT\"'"
          }
        ]
      }
    ]
  }
}
